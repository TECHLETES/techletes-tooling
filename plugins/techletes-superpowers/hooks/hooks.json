{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "uv run graphify hook-check",
            "statusMessage": "Checking command...",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "node \"${PLUGIN_ROOT}/hooks/ponytail/ponytail-activate.js\"",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:PLUGIN_ROOT\\hooks\\ponytail\\ponytail-activate.js\" }",
            "statusMessage": "Loading Techletes mode...",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "node \"${PLUGIN_ROOT}/hooks/ponytail/ponytail-subagent.js\"",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:PLUGIN_ROOT\\hooks\\ponytail\\ponytail-subagent.js\" }",
            "statusMessage": "Loading Techletes mode...",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "node \"${PLUGIN_ROOT}/hooks/ponytail/ponytail-mode-tracker.js\"",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:PLUGIN_ROOT\\hooks\\ponytail\\ponytail-mode-tracker.js\" }",
            "statusMessage": "Tracking Techletes mode...",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
